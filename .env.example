# Copy this file to .env and fill in your values. Never commit .env.

# Path to your GGUF model file (required — can also pass as --model on the CLI)
MODEL_PATH=./models/your-model-q4_k_m.gguf

# Bearer token for the private /api/prime endpoint.
# Leave empty to disable authentication on that route.
# Never pass this as a CLI flag — it would appear in process listings.
PRIME_TOKEN=

# Optional overrides (all have defaults; can also be set via CLI flags)
# PORT=8080
# MEMORY_DEPTH=10
