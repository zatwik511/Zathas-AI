# Copy this file to .env and fill in your values. Never commit .env.

# Path to your GGUF model file (required — can also pass as --model on the CLI)
MODEL_PATH=./models/your-model-q4_k_m.gguf

# Bearer token for the private /api/prime endpoint.
# Leave empty to disable authentication on that route.
# Never pass this as a CLI flag — it would appear in process listings.
PRIME_TOKEN=

# Groq API key — enables cloud inference on the public route (/api/chat).
# When set, MODEL_PATH is only needed for the private route (/api/prime).
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# Cloud model to use when GROQ_API_KEY is set (default shown below).
# Other options: llama-3.1-8b-instant, mixtral-8x7b-32768
CLOUD_MODEL=llama-3.3-70b-versatile

# Optional overrides (all have defaults; can also be set via CLI flags)
# PORT=8080
# MEMORY_DEPTH=10
