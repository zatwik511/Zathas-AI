.vscode/
.vs/
*.user
Thumbs.db
.DS_Store
desktop.ini

# Claude Code local settings
.claude/

# Node / frontend build artefacts (if a React frontend is added later)
node_modules/
frontend-react/dist/

# Legacy / misc
ggml/
memory.json
